# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/food-ordering

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Credentials (change in production)
ADMIN_EMAIL=admin@foodordering.com
ADMIN_PASSWORD=Admin@123456

# Email Configuration (for OTP)
# For Gmail: Use App Password from Google Account
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_16_digits

# Stripe (optional - remove if not using)
# STRIPE_SECRET_KEY=sk_test_placeholder
# STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Cloudinary (optional)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret